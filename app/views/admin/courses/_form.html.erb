<section class="course-admin course-admin--form">
  <div class="course-admin__shell course-admin__shell--form">
    <header class="course-admin__header course-admin__header--form">
      <div>
        <p class="course-admin__eyebrow">
          <%= course.persisted? ? "Update Course" : "Create Course" %>
        </p>
        <h1 class="course-admin__title">
          <%= course.persisted? ? "Edit Course" : "Add Course" %>
        </h1>
        <p class="course-admin__subtitle">
          Keep names clear and course codes unique so admins and teachers can identify courses quickly.
        </p>
      </div>
      <%= link_to "Back to Courses", admin_courses_path, class: "course-admin__ghost-link" %>
    </header>

    <div class="course-admin__form-shell">
      <%= form_for [:admin, course], html: { class: "course-admin__form" } do |f| %>
        <%= render "shared/error", model: course %>

        <div class="course-admin__field">
          <%= f.label :name, class: "course-admin__label" %>
          <%= f.text_field :name,
              placeholder: "Enter course name",
              autofocus: true,
              required: true,
              maxlength: 120,
              class: "course-admin__input" %>
        </div>

        <div class="course-admin__field">
          <%= f.label :coursecode, "Course Code", class: "course-admin__label" %>
          <%= f.text_field :coursecode,
              placeholder: "e.g. CS101",
              required: true,
              maxlength: 25,
              class: "course-admin__input course-admin__input--code" %>
        </div>

        <div class="course-admin__form-actions">
          <%= link_to "Cancel", admin_courses_path, class: "course-admin__secondary-button" %>
          <%= f.submit(course.persisted? ? "Save Changes" : "Create Course", class: "course-admin__primary-button") %>
        </div>
      <% end %>
    </div>
  </div>
</section>
