<section class="auth-register">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-12 col-md-10 col-lg-7 col-xl-6">
        <div class="card auth-register__card border-0 shadow-lg">
          <div class="card-body p-4 p-md-5">
            <div class="text-center mb-4">
              <span class="auth-register__icon bi bi-box-arrow-in-right"></span>
              <h2 class="auth-register__title mt-3 mb-1">Welcome Back</h2>
              <p class="auth-register__subtitle mb-0">
                Log in to continue to <%= resource_name.to_s.humanize %> portal.
              </p>
            </div>

            <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "auth-register__form" }) do |f| %>
              <div class="mb-3">
                <%= f.label :email, class: "form-label fw-semibold" %>
                <%= f.email_field :email,
                    class: "form-control form-control-lg",
                    autofocus: true,
                    autocomplete: "email",
                    placeholder: "you@example.com" %>
              </div>

              <div class="mb-3">
                <%= f.label :password, class: "form-label fw-semibold" %>
                <%= f.password_field :password,
                    class: "form-control form-control-lg",
                    autocomplete: "current-password",
                    placeholder: "Enter your password" %>
              </div>

              <% if devise_mapping.rememberable? %>
                <div class="mb-4 form-check">
                  <%= f.check_box :remember_me, class: "form-check-input" %>
                  <%= f.label :remember_me, class: "form-check-label" %>
                </div>
              <% end %>

              <%= f.submit "Log in", class: "btn btn-primary btn-lg w-100 auth-register__submit" %>
            <% end %>

            <div class="text-center mt-4 d-flex flex-column gap-2">
              <% if devise_mapping.registerable? %>
                <%= link_to "Don't have an account? Sign up", new_registration_path(resource_name), class: "auth-register__login-link" %>
              <% end %>
              <% if devise_mapping.recoverable? %>
                <%= link_to "Forgot your password?", new_password_path(resource_name), class: "auth-register__login-link" %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
