<section class="auth-register">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-12 col-md-10 col-lg-7 col-xl-6">
        <div class="card auth-register__card border-0 shadow-lg">
          <div class="card-body p-4 p-md-5">
            <div class="text-center mb-4">
              <span class="auth-register__icon bi bi-person-plus"></span>
              <h2 class="auth-register__title mt-3 mb-1">Create Account</h2>
              <p class="auth-register__subtitle mb-0">
                Sign up to continue to <%= resource_name.to_s.humanize %> portal.
              </p>
            </div>

            <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "auth-register__form" }) do |f| %>
              <% if resource.errors.any? %>
                <div class="alert alert-danger" role="alert">
                  <strong class="d-block mb-1">Please fix the following:</strong>
                  <ul class="mb-0 ps-3">
                    <% resource.errors.full_messages.each do |message| %>
                      <li><%= message %></li>
                    <% end %>
                  </ul>
                </div>
              <% end %>

              <div class="mb-3">
                <%= f.label :email, class: "form-label fw-semibold" %>
                <%= f.email_field :email,
                    autofocus: true,
                    autocomplete: "email",
                    class: "form-control form-control-lg",
                    placeholder: "you@example.com" %>
              </div>

              <div class="mb-3">
                <%= f.label :password, class: "form-label fw-semibold d-flex align-items-center gap-2" do %>
                  <span>Password</span>
                  <% if @minimum_password_length %>
                    <small class="text-muted fw-normal">(<%= @minimum_password_length %> characters min)</small>
                  <% end %>
                <% end %>
                <%= f.password_field :password,
                    autocomplete: "new-password",
                    class: "form-control form-control-lg",
                    placeholder: "Create a password" %>
              </div>

              <div class="mb-4">
                <%= f.label :password_confirmation, class: "form-label fw-semibold" %>
                <%= f.password_field :password_confirmation,
                    autocomplete: "new-password",
                    class: "form-control form-control-lg",
                    placeholder: "Repeat your password" %>
              </div>

              <%= f.submit "Sign up", class: "btn btn-primary btn-lg w-100 auth-register__submit" %>
            <% end %>

            <div class="text-center mt-4">
              <%= link_to "Already have an account? Log in", new_session_path(resource_name), class: "auth-register__login-link" %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
